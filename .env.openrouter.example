# ── OpenRouter (free AI models) ─────────────────────────────────────
# Powers the Somali product-description writer + the public help assistant.
# Get a FREE key at https://openrouter.ai/keys and paste it into .env.local.
# Preferred over Gemini (lib/ai picks OpenRouter first when this is set).

OPENROUTER_API_KEY=

# Optional — default is a free multimodal model used for both chat and images:
# OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
# OPENROUTER_VISION_MODEL=google/gemma-4-26b-a4b-it:free
