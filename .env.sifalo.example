# ── Sifalo Pay gateway ──────────────────────────────────────────────
# Copy the values you get after signing up at https://pay.sifalo.com/auth/signup
# into your .env.local. Until these are set, checkout runs Sifalo in MOCK mode
# (payments auto-approve) so the flow is testable; setting them switches to the
# live API with no code change.

# Option A (recommended): username + api key — we build a standard base64
# `Basic base64(user:key)` Authorization header (confirmed against the live API).
SIFALO_API_USERNAME=
SIFALO_API_PASSWORD=

# Option B: provide the full Authorization header value verbatim (overrides A).
# SIFALO_AUTH=Basic <base64 of user:key>

# Optional overrides (sane defaults baked in):
# SIFALO_API_BASE=https://api.sifalopay.com/gateway
# SIFALO_CURRENCY=USD            # USD | SLSH
